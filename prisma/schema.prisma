generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  jobs      Job[]
  createdAt DateTime @default(now())
}

model Job {
  id          String     @id @default(uuid())
  title       String
  company     String
  status      JobStatus  @default(APPLIED)
  appliedDate DateTime?
  resumeUrl   String?
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  createdAt   DateTime   @default(now())
}

enum JobStatus {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}